remote "https://github.com/acme/widgets.git"
poll-interval "10s"
check-spec ".gauntlet.kdl"        // path within each repo tree; optional, default ".gauntlet.kdl"
committer {
    name "Gauntlet"
    email "gauntlet@ci.acme.example"
}
merge-message "Merge {{.Topic}} ({{.User}})"   // optional
log-retention "720h"   // optional; default 30 days ("720h"); full per-check log files under <state>/logs

target "main" branch="main" {
    // Post-land hooks (optional, ordered, multiple allowed): run against
    // the landed tree once a candidate lands on this target. See README's
    // "Hooks" section — gauntlet never grows a CD system here; a hook
    // hands off to a real one when deployment needs grow.
    // hook "deploy" {
    //     command "make" "deploy"
    // }

    // hooks-policy (optional; default "queue"; only meaningful with at
    // least one hook above) controls what happens to this target's hook
    // backlog when landings outpace hook execution (e.g. deploys slower
    // than merges) — see README's "Backlog policies": "queue" runs every
    // landing's hooks, none dropped; "coalesce" drops a still-queued
    // landing once a newer one for this target queues behind it, keeping
    // only the newest; "cancel" additionally cancels a landing's hooks
    // mid-run when a newer one arrives, so a slow deploy never blocks the
    // latest candidate from deploying next.
    // hooks-policy "coalesce"

    // mode (optional; default "serial") selects this target's queueing
    // discipline (docs/plans/phase5.md §0, §4) — "serial" tests and lands
    // one candidate at a time (this target's actual behavior, unchanged
    // from phase 1); "batch" and "speculate" are opt-in, see the "release"
    // and "staging" targets below.
    // mode "serial"
}
target "release" branch="release/v2" {
    // Batch: merge up to max-batch queued candidates into one --no-ff
    // chain and run a single check suite over the combined tree — fewer
    // CI runs at the cost of coarser attribution when the batch goes red
    // (docs/plans/phase5.md §2.6: on-batch-red falls back to serial,
    // landing member by member, until the culprit is found and parked,
    // then batching resumes).
    // mode "batch"
    // max-batch 8              // optional; default 8; legal only with mode "batch"
    // on-batch-red "serial"    // optional; default "serial"; "bisect" is
    //                          // reserved for a future release and
    //                          // rejected at load if set
}

// Speculate: pipeline "window" candidates, each tested on the predicted
// landing of the ones ahead of it — checks overlap, landings stay
// strictly FIFO (docs/plans/phase5.md §4.1). "window" also bounds how
// many check processes/containers this target drives concurrently against
// the build executor, so size it with builder capacity in mind.
// target "staging" branch="staging" {
//     mode "speculate"
//     window 4   // optional; default 4; legal only with mode "speculate"
// }

// --- phase 2/3 additions (all optional) ---

history "/var/lib/gauntlet/history.db" {
    sample-every "10s"
    depth-retention "336h"   // optional; default 14 days ("336h"); queue_depth series only
}

dashboard "localhost:8080" {
    url "https://gauntlet.internal.example"   // optional; used in outbound links
}

github "acme/widgets" {
    token-env "GITHUB_TOKEN"
    api-url "https://api.github.com"
}

slack "C0123456789" {
    app-token-env "SLACK_APP_TOKEN"
    bot-token-env "SLACK_BOT_TOKEN"
    // optional: only these Slack member IDs may command the queue via
    // reactions (:recycle: retry, :x: cancel). Omit to allow anyone who
    // can react in the channel.
    allowed-users "U025FTHN3" "U0987ZYXWV"
}

otlp "localhost:4318" {
    insecure true
}

executor "container" {
    runtime "container"
    image "ghcr.io/acme/ci:latest"
    workdir "/workspace"
    cache "gocache"    path="/root/.cache/go-build"
    cache "gomodcache" path="/go/pkg/mod"

    // mount (optional, multiple allowed): host bind mounts, e.g. the docker
    // socket so testcontainers-based checks can reach the host daemon. See
    // README's "Container executor" section for the trust implication
    // before uncommenting this — mounting the socket hands every check full
    // control of the host docker daemon.
    // mount "/var/run/docker.sock" path="/var/run/docker.sock"
}

// summarize {
//     model "claude-sonnet-5"           // optional; default shown
//     api-key-env "ANTHROPIC_API_KEY"   // optional; default shown
//     effort "medium"                   // optional; default shown — one of
//                                        // low|medium|high|xhigh|max, sent
//                                        // as output_config.effort; only
//                                        // valid on models that support it
//                                        // (e.g. NOT claude-haiku-4-5)
//     timeout "5s"                      // optional; default shown — runs
//                                        // synchronously on the reconcile
//                                        // loop before checks start, on
//                                        // every clean trial; bounds a
//                                        // stall of ALL targets' loop, so
//                                        // keep it well under poll-interval
// }
