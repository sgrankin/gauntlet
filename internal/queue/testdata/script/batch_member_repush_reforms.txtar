# Batch member re-pushed mid-check: bob (member 2 of 3) is force-updated
# while the batch's combined check is still gated in flight. The whole
# batch is invalidated — Skipped, NOT parked (§2.2's generalized Invariant
# 5: any member move invalidates the whole run, since a batch is one tested
# tree, it cannot partially invalidate) — and re-forms on the NEXT tick with
# bob's new content (constraint 3). Ports docs/plans/phase5.md §5.2's
# batch_member_repush_reforms row.

set-mode main batch 8

direct-push main files/spec       # see batch_green_lands_chain.txtar's comment: seed the spec once, up front

push-candidate main alice a files/a
push-candidate main bob b files/b-v1
push-candidate main carol c files/c
tick                                 # one refill: batch of 3 (alice,bob,carol); "test" starts once

await-started test

repush main bob b files/b-v2         # bob (member 2) re-pushed mid-check: new SHA, same ref
tick                                  # detects the move; whole batch invalidated: Skip all three, none parked

assert-event skipped
! assert-event rejected
! assert-event landed
! assert-slot-gone main alice a
! assert-slot-gone main bob b
! assert-slot-gone main carol c

tick                                   # re-forms: batch of 3 again, bob's NEW content this time
await-started test
release-check test passed              # green: lands all three, bob's re-pushed content included

assert-event landed
assert-landed-order main a b c
assert-slot-gone main alice a
assert-slot-gone main bob b
assert-slot-gone main carol c

-- files/spec/.gauntlet.kdl --
check "test" {
    command "true"
}
-- files/a/a.txt --
a
-- files/b-v1/NOTES.md --
first push
-- files/b-v2/NOTES.md --
re-pushed mid-check
-- files/c/c.txt --
c
